{
  "name": "bookstack-js-css",
  "version": "1.0.0",
  "description": "JS, CSS assests for WSU Docs (Bookstack)",
  "scripts": {
    "build:css": "node build-css.js",
    "postbuild:css": "npm run format:css",
    "format:check": "prettier --write .",
    "format:all": "prettier --write .",
    "format:css": "prettier --write 'docs/**/*.css' 'source/**/*.css'"
  },
  "type": "module",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "prettier": "^3.8.1"
  }
}
